#ifndef INC_STM32L476XX_H_
#define INC_STM32L476XX_H_


#define FLASH_BASE_ADDRESS              0x08000000u		// Main memory address
#define SRAM1_BASE_ADDRESS				0x20000000u		// SRAM1 Embedded Memory
#define SRAM2_BASE_ADDRESS				0x20018000u		// SRAM2 = SRAM1   +   96kb * 1024
#define ROM_BASE_ADDRESS                0x1FFF0000u		// System Memory address


#define AHB1_BASE_ADDRESS				0x40020000U
#define AHB2_BASE_ADDRESS				0x40024400U
#define APB1_BASE_ADDRESS				0x40000000U
#define APB2_BASE_ADDRESS				0x40010000U
#endif /* INC_STM32L476XX_H_ */
